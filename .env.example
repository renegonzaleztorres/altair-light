NODE_ENV="development"
APP_NAME="altair-light"
ACTIVE_SPACE="spaces/kinetic"
PUBLIC_LOCATION="public"
PAGES_LOCATION="pages"
DATA_LOCATION="data"
DATA_FILE="DATA.json"
ENABLE_DATA_WATCH=true
MINIFY=true
DEBUG=true

# WebSocket Configuration
ENABLE_WEBSOCKET=false
WEBSOCKET_PATH="/ws"
WEBSOCKET_HEARTBEAT_MS=30000
WEBSOCKET_SESSION_TTL_SECS=3600
# Allowed origins: "" (reject all), "*" (allow all - dev only), "same-origin", or comma-separated list
WEBSOCKET_ALLOWED_ORIGINS="same-origin"
